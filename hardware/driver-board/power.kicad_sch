	)
	(text_box "Divider formula: VADC = VBAT_SW * RLOW / (RHIGH + RLOW). Example with RHIGH = 100k and RLOW = 33k: VADC = VBAT_SW * 33k / 133k = VSW * 0.248, so 10.8 V on VBAT_SW becomes about 2.68 V at the STM32 ADC.\n"
		(exclude_from_sim no)
		(at 198.12 34.29 0)
		(size 45.72 15.24)
		(margins 0.9525 0.9525 0.9525 0.9525)
